<?xml version="1.0" encoding="utf-8"?>
<!-- Segmented model selector: active model uses the accent fill (state_selected). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/mec_accent_bg" />
            <corners android:radius="9dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/mec_btn_pressed" />
            <corners android:radius="9dp" />
            <stroke android:width="1dp" android:color="@color/mec_stroke" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/mec_btn" />
            <corners android:radius="9dp" />
            <stroke android:width="1dp" android:color="@color/mec_stroke" />
        </shape>
    </item>
</selector>
